nClick={()=>setForm(p=>({...p,color:col}))} style={{width:28,height:28,borderRadius:'50%',background:col,cursor:'pointer',border:form.color===col?'3px solid #fff':'3px solid transparent'}}/>)}</div></FF><div style={{...c.row,justifyContent:'flex-end',gap:10,marginTop:8}}><button style={{...c.btn,...c.secondary}} onClick={()=>setShowAdd(false)}>İptal</button><button style={{...c.btn,...c.primary}} onClick={save} disabled={saving}>{saving?'⏳':'Kaydet'}</button></div></Modal>)}</div>);};
const Payments=({user,payments,setPayments,members})=>{const [showAdd,setShowAdd]=useState(false);const [filter,setFilter]=useState('Tümü');const [saving,setSaving]=useState(false);const [form,setForm]=useState({member_id:'',amount:'',package:PACKAGES[0],method:'Kart',status:'Ödendi'});useEffect(()=>{if(members.length&&!form.member_id)setForm(p=>({...p,member_id:members[0].id}));},[members]);const filtered=filter==='Tümü'?payments:payments.filter(p=>p.status===filter);const total=payments.filter(p=>p.status==='Ödendi').reduce((s,p)=>s+p.amount,0);const pending=payments.filter(p=>p.status!=='Ödendi').reduce((s,p)=>s+p.amount,0);const save=async()=>{if(!form.amount||!form.member_id)return;setSaving(true);const {data}=await sb.from('payments').insert([{member_id:form.member_id,amount:parseInt(form.amount),package:form.package,method:form.method,status:form.status,date:new Date().toISOString().split('T')[0]}]).select().single();setSaving(false);if(data){setPayments(p=>[data,...p]);setShowAdd(false);setForm({member_id:members[0]?.id||'',amount:'',package:PACKAGES[0],method:'Kart',status:'Ödendi'});}};const getMember=id=>members.find(m=>m.id===id);return(<div className="fade"><div style={{...c.row,justifyContent:'space-between',marginBottom:20,flexWrap:'wrap',gap:10}}><div><h2 style={{fontSize:22,fontWeight:700,marginBottom:2}}>Ödeme Takibi</h2><p style={{color:'#6b6b8a',fontSize:13}}>Gelir ve tahsilat</p></div><button style={{...c.btn,...c.primary}} onClick={()=>setShowAdd(true)}>+ Ödeme Ekle</button></div><div style={{display:'grid',gridTemplateColumns:'repeat(auto-fit,minmax(130px,1fr))',gap:14,marginBottom:20}}>{[{lbl:'Tahsilat',val:`₺${total.toLocaleString()}`,cl:'#34d399',bg:'#0d2e1f',br:'#1a4d35'},{lbl:'Bekleyen',val:`₺${pending.toLocaleString()}`,cl:'#fbbf24',bg:'#2e2800',br:'#4d4000'},{lbl:'İşlem',val:payments.length,cl:'#a78bfa',bg:'#1e1e3a',br:'#2e2e5e'},{lbl:'Gecikmiş',val:payments.filter(p=>p.status==='Gecikmiş').length,cl:'#f87171',bg:'#3d1515',br:'#5c2020'}].map((s,i)=>(<div key={i} style={{...c.card,background:s.bg,border:`1px solid ${s.br}`,textAlign:'center',padding:'16px 10px'}}><div style={{fontSize:22,fontWeight:800,color:s.cl}}>{s.val}</div><div style={{fontSize:11,color:'#6b6b8a',marginTop:4}}>{s.lbl}</div></div>))}</div><div style={{...c.row,marginBottom:14,gap:8,flexWrap:'wrap'}}>{['Tümü','Ödendi','Bekliyor','Gecikmiş'].map(f=>(<button key={f} style={{...c.btn,...(filter===f?c.primary:c.secondary),padding:'7px 14px'}} onClick={()=>setFilter(f)}>{f}</button>))}</div><div style={{...c.card,overflowX:'auto'}}><table style={{width:'100%',borderCollapse:'collapse'}}><thead><tr>{['Üye','Paket','Tutar','Tarih','Yöntem','Durum'].map(h=><th key={h} style={c.th}>{h}</th>)}</tr></thead><tbody>{filtered.map(p=>{const m=getMember(p.member_id);return(<tr key={p.id}><td style={c.td}><span style={{fontWeight:600}}>{m?.name||'—'}</span></td><td style={{...c.td,fontSize:12,color:'#8888aa'}}>{p.package}</td><td style={{...c.td,fontWeight:700,color:'#34d399'}}>₺{p.amount?.toLocaleString()}</td><td style={{...c.td,fontSize:12,color:'#8888aa'}}>{p.date}</td><td style={{...c.td,fontSize:12}}>{p.method}</td><td style={c.td}><Badge status={p.status}/></td></tr>);})}</tbody></table>{filtered.length===0&&<p style={{textAlign:'center',color:'#6b6b8a',padding:32}}>Kayıt bulunamadı</p>}</div>{showAdd&&(<Modal title="Ödeme Ekle" onClose={()=>setShowAdd(false)}><FF label="Üye"><select style={c.input} value={form.member_id} onChange={e=>setForm(p=>({...p,member_id:e.target.value}))}>{members.map(m=><option key={m.id} value={m.id}>{m.name}</option>)}</select></FF><div style={c.grid2}><FF label="Paket"><select style={c.input} value={form.package} onChange={e=>setForm(p=>({...p,package:e.target.value}))}>{PACKAGES.map(pk=><option key={pk}>{pk}</option>)}</select></FF><FF label="Tutar (₺)"><input style={c.input} type="number" value={form.amount} onChange={e=>setForm(p=>({...p,amount:e.target.value}))} placeholder="1800"/></FF></div><div style={c.grid2}><FF label="Yöntem"><select style={c.input} value={form.method} onChange={e=>setForm(p=>({...p,method:e.target.value}))}>{['Kart','Nakit','Havale'].map(m=><option key={m}>{m}</option>)}</select></FF><FF label="Durum"><select style={c.input} value={form.status} onChange={e=>setForm(p=>({...p,status:e.target.value}))}>{['Ödendi','Bekliyor','Gecikmiş'].map(s=><option key={s}>{s}</option>)}</select></FF></div><div style={{...c.row,justifyContent:'flex-end',gap:10,marginTop:8}}><button style={{...c.btn,...c.secondary}} onClick={()=>setShowAdd(false)}>İptal</button><button style={{...c.btn,...c.primary}} onClick={save} disabled={saving}>{saving?'⏳':'Kaydet'}</button></div></Modal>)}</div>);};
const Instructors=({allUsers,classes,members})=>(<div className="fade"><h2 style={{fontSize:22,fontWeight:700,marginBottom:4}}>Ekip Yönetimi</h2><p style={{color:'#6b6b8a',fontSize:13,marginBottom:20}}>Tüm personel ve hocalar</p><div style={{display:'grid',gridTemplateColumns:'repeat(auto-fill,minmax(260px,1fr))',gap:16}}>{allUsers.map(u=>{const myClasses=classes.filter(cl=>cl.instructor_id===u.id);return(<div key={u.id} style={{...c.card,borderTop:`3px solid ${ROLE_COLORS[u.role]}`}}><div style={c.row}><div style={{...c.avatar,width:46,height:46,fontSize:15,border:`2px solid ${ROLE_COLORS[u.role]}`}}>{u.avatar||initials(u.name)}</div><div><div style={{fontWeight:700,fontSize:15}}>{u.name}</div><span style={{padding:'2px 8px',borderRadius:12,fontSize:11,fontWeight:600,background:`${ROLE_COLORS[u.role]}22`,color:ROLE_COLORS[u.role],border:`1px solid ${ROLE_COLORS[u.role]}44`}}>{ROLE_LABELS[u.role]}</span></div></div><div style={{marginTop:14,paddingTop:14,borderTop:'1px solid #1e1e2e',display:'grid',gridTemplateColumns:'1fr 1fr',gap:10}}><div><div style={{fontSize:22,fontWeight:800,color:'#a78bfa'}}>{myClasses.length}</div><div style={{fontSize:11,color:'#6b6b8a'}}>Aktif Ders</div></div><div><div style={{fontSize:22,fontWeight:800,color:'#34d399'}}>{members.length}</div><div style={{fontSize:11,color:'#6b6b8a'}}>Üye</div></div></div>{myClasses.length>0&&<div style={{marginTop:12}}>{myClasses.slice(0,3).map(cl=>(<div key={cl.id} style={{...c.row,fontSize:12,marginBottom:4,gap:6}}><span style={{width:7,height:7,borderRadius:'50%',background:cl.color,flexShrink:0}}/><span style={{color:'#8888aa'}}>{cl.name} — {cl.day} {cl.time}</span></div>))}</div>}</div>);})}</div></div>);
const Reports=({payments,members,classes})=>{const total=payments.filter(p=>p.status==='Ödendi').reduce((s,p)=>s+p.amount,0);const byPkg=PACKAGES.map(pkg=>({name:pkg,count:members.filter(m=>m.package===pkg).length,rev:payments.filter(p=>p.package===pkg&&p.status==='Ödendi').reduce((s,p)=>s+p.amount,0)})).filter(p=>p.count>0);const byDay=DAYS.map(d=>({day:d,count:classes.filter(cl=>cl.day===d).length}));const maxDay=Math.max(...byDay.map(d=>d.count),1);return(<div className="fade"><h2 style={{fontSize:22,fontWeight:700,marginBottom:4}}>Raporlar</h2><p style={{color:'#6b6b8a',fontSize:13,marginBottom:20}}>İşletme istatistikleri</p><div style={{display:'grid',gridTemplateColumns:'1fr 1fr',gap:16}}><div style={c.card}><h3 style={{margin:'0 0 16px',fontSize:14,color:'#a78bfa'}}>📦 Paket Dağılımı</h3>{byPkg.length===0?<p style={{color:'#6b6b8a',fontSize:13}}>Veri yok</p>:byPkg.map(p=>(<div key={p.name} style={{marginBottom:12}}><div style={{display:'flex',justifyContent:'space-between',marginBottom:4}}><span style={{fontSize:12}}>{p.name}</span><span style={{fontSize:12,color:'#34d399',fontWeight:700}}>₺{p.rev.toLocaleString()}</span></div><div style={{background:'#1e1e2e',borderRadius:4,height:5}}><div style={{background:'linear-gradient(90deg,#a78bfa,#60a5fa)',borderRadius:4,height:5,width:`${(p.count/members.length)*100}%`}}/></div><span style={{fontSize:10,color:'#6b6b8a'}}>{p.count} üye</span></div>))}</div><div style={c.card}><h3 style={{margin:'0 0 16px',fontSize:14,color:'#34d399'}}>📅 Günlük Yoğunluk</h3>{byDay.map(d=>(<div key={d.day} style={{marginBottom:9}}><div style={{display:'flex',justifyContent:'space-between',marginBottom:3}}><span style={{fontSize:12}}>{d.day}</span><span style={{fontSize:11,color:'#8888aa'}}>{d.count} ders</span></div><div style={{background:'#1e1e2e',borderRadius:4,height:5}}><div style={{background:'linear-gradient(90deg,#34d399,#059669)',borderRadius:4,height:5,width:`${(d.count/maxDay)*100}%`}}/></div></div>))}</div><div style={c.card}><h3 style={{margin:'0 0 16px',fontSize:14,color:'#fbbf24'}}>💰 Gelir Özeti</h3>{[['Toplam Tahsilat',`₺${total.toLocaleString()}`,'#34d399'],['Bekleyen',`₺${payments.filter(p=>p.status!=='Ödendi').reduce((s,p)=>s+p.amount,0).toLocaleString()}`,'#f87171'],['Toplam İşlem',payments.length,'#a78bfa'],['Ort. Tutar',`₺${Math.round(total/(payments.filter(p=>p.status==='Ödendi').length||1)).toLocaleString()}`,'#fbbf24']].map(([k,v,cl])=>(<div key={k} style={{padding:'9px 0',borderBottom:'1px solid #1e1e2e',display:'flex',justifyContent:'space-between'}}><span style={{fontSize:13,color:'#8888aa'}}>{k}</span><span style={{fontSize:14,fontWeight:700,color:cl}}>{v}</span></div>))}</div><div style={c.card}><h3 style={{margin:'0 0 16px',fontSize:14,color:'#fb923c'}}>🎯 Ders Doluluk</h3>{classes.map(cl=>{const pct=Math.round(((cl.enrolled||[]).length/cl.capacity)*100);return(<div key={cl.id} style={{marginBottom:10}}><div style={{display:'flex',justifyContent:'space-between',marginBottom:3}}><span style={{fontSize:12}}>{cl.name} — {cl.day}</span><span style={{fontSize:12,fontWeight:700,color:pct>=80?'#34d399':pct>=50?'#fbbf24':'#f87171'}}>%{pct}</span></div><div style={{background:'#1e1e2e',borderRadius:4,height:5}}><div style={{background:pct>=80?'#34d399':pct>=50?'#fbbf24':'#f87171',borderRadius:4,height:5,width:`${pct}%`}}/></div></div>);})} {classes.length===0&&<p style={{color:'#6b6b8a',fontSize:13}}>Ders yok</p>}</div></div></div>);};
const App=()=>{const [user,setUser]=useState(null);const [page,setPage]=useState('dashboard');const [members,setMembers]=useState([]);const [classes,setClasses]=useState([]);const [payments,setPayments]=useState([]);const [allUsers,setAllUsers]=useState([]);const [loading,setLoading]=useState(false);const [sidebarOpen,setSidebarOpen]=useState(false);const [isMobile,setIsMobile]=useState(window.innerWidth<768);useEffect(()=>{const h=()=>setIsMobile(window.innerWidth<768);window.addEventListener('resize',h);return()=>window.removeEventListener('resize',h);},[]);const loadData=useCallback(async()=>{setLoading(true);const [m,cl,p,u]=await Promise.all([sb.from('members').select('*').order('created_at',{ascending:false}),sb.from('classes').select('*').order('time'),sb.from('payments').select('*').order('created_at',{ascending:false}),sb.from('users').select('*')]);setMembers(m.data||[]);setClasses(cl.data||[]);setPayments(p.data||[]);setAllUsers(u.data||[]);setLoading(false);},[]);useEffect(()=>{if(user)loadData();},[user,loadData]);if(!user)return <Login onLogin={u=>{setUser(u);setPage('dashboard');}}/>;const NAV=[{id:'dashboard',icon:'🏠',label:'Ana Sayfa'},{id:'members',icon:'👥',label:'Üyeler'},{id:'schedule',icon:'📅',label:'Ders Programı'},...(can(user.role,'viewPayments')?[{id:'payments',icon:'💰',label:'Ödemeler'}]:[]),...(can(user.role,'manageInstructors')?[{id:'instructors',icon:'🧑‍🏫',label:'Ekip'},{id:'reports',icon:'📊',label:'Raporlar'}]:[])];const Sidebar=()=>(<><div style={c.logo}><div style={{fontSize:19,fontWeight:800,color:'#a78bfa'}}>🧘 StüdyoApp</div><div style={{fontSize:11,color:'#6b6b8a',marginTop:2}}>Pilates Yönetim Sistemi</div></div><div style={{padding:'10px 6px',borderBottom:'1px solid #1e1e2e'}}><div style={c.row}><div style={{...c.avatar,border:`2px solid ${ROLE_COLORS[user.role]}`}}>{user.avatar||initials(user.name)}</div><div style={{flex:1,minWidth:0}}><div style={{fontSize:13,fontWeight:600,overflow:'hidden',textOverflow:'ellipsis',whiteSpace:'nowrap'}}>{user.name}</div><div style={{fontSize:11,color:ROLE_COLORS[user.role]}}>{ROLE_LABELS[user.role]}</div></div><button onClick={()=>setUser(null)} style={{background:'none',border:'none',color:'#6b6b8a',cursor:'pointer',fontSize:18}}>⏏</button></div></div><nav style={c.nav}>{NAV.map(n=>(<div key={n.id} style={{...c.navItem,...(page===n.id?c.navActive:{})}} onClick={()=>{setPage(n.id);setSidebarOpen(false);}}><span style={{fontSize:16,width:20,textAlign:'center'}}>{n.icon}</span><span>{n.label}</span></div>))}</nav><div style={{padding:'12px 16px',borderTop:'1px solid #1e1e2e'}}><button onClick={loadData} style={{...c.btn,...c.secondary,width:'100%',fontSize:12}}>🔄 Yenile</button></div></>);return(<div style={c.app}>{isMobile?(<>{sidebarOpen&&<div style={{position:'fixed',inset:0,background:'rgba(0,0,0,0.6)',zIndex:150}} onClick={()=>setSidebarOpen(false)}/>}<div style={{...c.sidebar,transform:sidebarOpen?'translateX(0)':'translateX(-100%)',transition:'transform 0.25s',zIndex:200}}><Sidebar/></div></>):(<div style={c.sidebar}><Sidebar/></div>)}<div style={{...c.main,...(isMobile?{marginLeft:0}:{})}}><div style={c.topbar}><div style={c.row}>{isMobile&&<button onClick={()=>setSidebarOpen(!sidebarOpen)} style={{background:'none',border:'none',color:'#a78bfa',cursor:'pointer',fontSize:24,padding:0,marginRight:8}}>☰</button>}<span style={{fontSize:13,color:'#6b6b8a'}}>{NAV.find(n=>n.id===page)?.icon} {NAV.find(n=>n.id===page)?.label}</span></div><span style={{fontSize:12,color:'#4a4a6a'}}>{new Date().toLocaleDateString('tr-TR',{weekday:'short',day:'numeric',month:'short'})}</span></div><div style={c.content}>{loading?<Loader/>:(<>{page==='dashboard'&&<Dashboard user={user} members={members} classes={classes} payments={payments}/>}{page==='members'&&<Members user={user} members={members} setMembers={setMembers}/>}{page==='schedule'&&<Schedule user={user} classes={classes} setClasses={setClasses}/>}{page==='payments'&&can(user.role,'viewPayments')&&<Payments user={u